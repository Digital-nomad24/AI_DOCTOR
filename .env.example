# Copy to .env and fill in values (never commit real secrets).

# Groq: vision + LLM (analyze_image_with_query, etc.)
GROQ_API_KEY=

# Deepgram: speech-to-text (voice input) and text-to-speech when AI_DOCTOR_TTS=deepgram
DEEPGRAM_API_KEY=

# TTS backend: gtts | elevenlabs | deepgram
AI_DOCTOR_TTS=gtts

# Optional: Deepgram Listen STT model (default nova-3)
# AI_DOCTOR_DEEPGRAM_STT_MODEL=nova-3

# Optional: live STT tuning (streaming mic -> Deepgram batch transcribe)
# AI_DOCTOR_STREAM_BUFFER_SECONDS=60
# AI_DOCTOR_STREAM_EVERY=0.8
# AI_DOCTOR_STREAM_TIME_LIMIT=300

# ElevenLabs (only when AI_DOCTOR_TTS=elevenlabs)
# ELEVENLABS_API_KEY=

# Set to 0 to skip MP3 generation
# AI_DOCTOR_ENABLE_TTS=1
