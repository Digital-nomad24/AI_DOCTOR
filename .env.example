# Required for Groq (transcription + vision/text)
GROQ_API_KEY=

# Optional: override Groq chat model id (vision-capable)
# AI_DOCTOR_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional: download best_model.h5 for the tissue-classifier demo branch
MODEL_URL=

# ElevenLabs TTS (only if AI_DOCTOR_TTS=elevenlabs)
ELEVENLABS_API_KEY=

# TTS backend: gtts (default) | elevenlabs
AI_DOCTOR_TTS=gtts

# Set to 0 to skip MP3 generation (Groq text response still shown)
AI_DOCTOR_ENABLE_TTS=1

# Set to 1 to open a public URL via pyngrok (also default when running hh.py unless overridden here)
USE_NGROK=0

# Set to 1 to play MP3 through the server's speakers (Windows/macOS local only)
AI_DOCTOR_SERVER_PLAY_AUDIO=0

# ngrok authtoken (only if USE_NGROK=1)
# NGROK_AUTHTOKEN=
